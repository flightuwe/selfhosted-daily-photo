# Replace with your real subdomain routed by Synology Reverse Proxy
PUBLIC_BASE_URL=https://daily.teacloud.synology.me
CORS_ORIGINS=https://daily.teacloud.synology.me

# Generate with a password manager or random generator (at least 32 chars)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Initial admin user for first login
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Keep this aligned with your user timezone
APP_TIMEZONE=Europe/Berlin

# Firebase Cloud Messaging (server-side)
FCM_ENABLED=true
FCM_PROJECT_ID=REPLACE_WITH_FIREBASE_PROJECT_ID
# Service account JSON file location on Synology host:
# /volume1/docker/selfhosted-daily-photo/secrets/firebase-service-account.json

# Synology host path used in portainer-stack.yml
# /volume1/docker/selfhosted-daily-photo/backend-data

# Direct local test URL (without reverse proxy)
# http://192.168.178.80:13379
