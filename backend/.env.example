APP_ADDRESS=:8080
DB_PATH=/app/data/app.db
UPLOAD_DIR=/app/data/uploads
JWT_SECRET=change-me
TOKEN_TTL_HOURS=72
CORS_ORIGINS=*
PUBLIC_BASE_URL=https://your-domain.example
APP_TIMEZONE=Europe/Berlin
SCHEDULER_ENABLED=true
APP_VERSION=dev
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong
FCM_ENABLED=false
FCM_PROJECT_ID=your-firebase-project-id
FCM_SERVICE_ACCOUNT_FILE=/app/secrets/firebase-service-account.json
FORENSIC_BACKEND_LOG_PATH=/app/logs/backend.log
FORENSIC_GATEWAY_LOG_PATH=/app/gateway-logs/access.log
SQLITE_MAX_OPEN_CONNS=1
SQLITE_MAX_IDLE_CONNS=1
